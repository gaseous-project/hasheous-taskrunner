{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Task Runner",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "osx": {
                "program": "${workspaceFolder}/hasheous-taskrunner/bin/Debug/net8.0/osx-arm64/hasheous-taskrunner.dll"
            },
            "windows": {
                "program": "${workspaceFolder}/hasheous-taskrunner/bin/Debug/net8.0/win-x64/hasheous-taskrunner.dll"
            },
            "linux": {
                "program": "${workspaceFolder}/hasheous-taskrunner/bin/Debug/net8.0/linux-x64/hasheous-taskrunner.dll"
            },
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        }
    ]
}